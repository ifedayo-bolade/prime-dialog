<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="DefaultDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowIsFloating">true</item>
    </style>

    <style name="FlashAnimation">
        <item name="android:windowEnterAnimation">@anim/prime_dialog_flash_fade_in</item>
        <item name="android:windowExitAnimation">@anim/prime_dialog_flash_fade_out</item>
    </style>

    <style name="FadeAnimation">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="SlideAnimation">
        <item name="android:windowEnterAnimation">@anim/prime_dialog_bottom_to_top</item>
        <item name="android:windowExitAnimation">@anim/prime_dialog_top_to_bottom</item>
    </style>
</resources>