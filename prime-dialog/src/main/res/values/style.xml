<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="DefaultDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
    </style>

    <style name="Flash" parent="DefaultDialogTheme">
        <item name="android:windowEnterAnimation">@anim/dialog_fast_fade_in</item>
        <item name="android:windowExitAnimation">@anim/dialog_fast_fade_out</item>
    </style>

    <style name="Fade" parent="DefaultDialogTheme">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="Slide" parent="DefaultDialogTheme">
        <item name="android:windowEnterAnimation">@anim/dialog_bottom_to_top</item>
        <item name="android:windowExitAnimation">@anim/dialog_top_to_bottom</item>
    </style>
</resources>